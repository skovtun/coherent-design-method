{
  "name": "coherent-design-method",
  "version": "0.1.0",
  "description": "AI-powered design system generator with stateful component management - BMAD for frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter '@coherent/*' build",
    "dev": "pnpm --filter '@coherent/*' dev",
