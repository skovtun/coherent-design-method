    "test": "pnpm --filter '@coherent/*' test",
    "lint": "pnpm --filter '@coherent/*' lint",
    "test:quality": "bash packages/cli/tests/quality-smoke.sh"
  },
  "keywords": [
    "design-system",
    "cli",
    "frontend",
    "ai",
    "code-generation",
    "nextjs",
    "react"
  ],
