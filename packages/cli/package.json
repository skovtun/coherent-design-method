{
  "name": "@getcoherent/cli",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.6.100",
  "description": "CLI interface for Coherent Design Method",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "coherent": "./bin/coherent"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skovtun/coherent-design-method.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "design-system",
    "cli",
    "frontend",
    "ai",
    "code-generation",
    "nextjs",
    "react",
    "coherent"
  ],
  "author": "Coherent Design Method",
  "license": "MIT",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "postbuild": "node scripts/check-constraint-budget.mjs",
    "check-budget": "node scripts/check-constraint-budget.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "node -e \"if (!(process.env.npm_config_user_agent || '').includes('pnpm')) { console.error('\\n❌ Use pnpm publish, not npm publish.\\nReason: npm does not resolve workspace:* protocol, publishing will break global install.\\nRun: pnpm publish --no-git-checks\\n'); process.exit(1); }\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@getcoherent/core": "workspace:*",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.1",
    "commander": "^11.1.0",
    "dotenv": "^16.4.5",
    "open": "^10.1.0",
    "ora": "^7.0.1",
    "prompts": "^2.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
